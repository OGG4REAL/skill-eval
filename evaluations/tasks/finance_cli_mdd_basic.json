{
  "task_id": "finance_cli_mdd_basic",
  "group": "finance_uplift",
  "eval_type": "uplift",
  "description": "验证风险指标序列计算场景下，agent 是否能返回可直接校验的结构化 JSON 结果。",
  "input": {
    "user_query": "给定净值序列 1.0, 1.1, 0.95, 1.2, 0.8，最大回撤是多少？",
    "session_setup": {
      "uploads": [],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "fin-advisor-math"
  ],
  "expected_signals": [
    "skill:fin-advisor-math",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 8
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "fin-advisor-math"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "max_drawdown",
      "max_drawdown_percent"
    ],
    "notes": [
      "max_drawdown 返回数字",
      "max_drawdown_percent 返回带百分号的字符串"
    ]
  },
  "ground_truth": {
    "max_drawdown": 0.333333,
    "max_drawdown_percent": "33.33%"
  },
  "verifier": {
    "mode": "rubric",
    "target": "final_response_json",
    "checks": [
      {
        "id": "max_drawdown",
        "type": "numeric_tolerance",
        "path": "max_drawdown",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.6
      },
      {
        "id": "max_drawdown_percent",
        "type": "exact_match",
        "path": "max_drawdown_percent",
        "weight": 0.4
      }
    ]
  }
}