{
  "task_id": "finance_tier2_multi_rate_compare",
  "group": "finance_uplift",
  "eval_type": "uplift",
  "description": "验证多收益率对比场景下，agent 是否能返回可直接校验的结构化 JSON 结果。",
  "input": {
    "user_query": "本金 30 万目标 100 万，比较年化 6%、8%、10%、12% 分别需要多少年。",
    "session_setup": {
      "uploads": [],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "fin-advisor-math"
  ],
  "expected_signals": [
    "skill:fin-advisor-math",
    "tool:Read:/workspace/skills/fin-advisor-math/scripts/finance_formulas.py",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 12
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "fin-advisor-math"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "years_by_rate",
      "fastest_rate",
      "fastest_years",
      "slowest_rate",
      "slowest_years"
    ],
    "notes": [
      "years_by_rate 的键固定为 6%、8%、10%、12%",
      "years 值返回数字并保留两位小数"
    ]
  },
  "ground_truth": {
    "years_by_rate": {
      "6%": 20.66,
      "8%": 15.64,
      "10%": 12.63,
      "12%": 10.62
    },
    "fastest_rate": "12%",
    "fastest_years": 10.62,
    "slowest_rate": "6%",
    "slowest_years": 20.66
  },
  "verifier": {
    "mode": "rubric",
    "target": "final_response_json",
    "checks": [
      {
        "id": "years_6",
        "type": "numeric_tolerance",
        "path": "years_by_rate.6%",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "years_8",
        "type": "numeric_tolerance",
        "path": "years_by_rate.8%",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "years_10",
        "type": "numeric_tolerance",
        "path": "years_by_rate.10%",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "years_12",
        "type": "numeric_tolerance",
        "path": "years_by_rate.12%",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "fastest_rate",
        "type": "exact_match",
        "path": "fastest_rate",
        "weight": 0.1
      },
      {
        "id": "fastest_years",
        "type": "numeric_tolerance",
        "path": "fastest_years",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.05
      },
      {
        "id": "slowest_rate",
        "type": "exact_match",
        "path": "slowest_rate",
        "weight": 0.025
      },
      {
        "id": "slowest_years",
        "type": "numeric_tolerance",
        "path": "slowest_years",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.025
      }
    ]
  }
}