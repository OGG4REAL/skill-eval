{
  "task_id": "csv_analysis_clean_financial",
  "group": "csv_uplift",
  "eval_type": "uplift",
  "description": "验证 skill 在干净财务 CSV 上，是否能通过脚本按财务口径计算关键聚合指标并输出结构化 JSON。",
  "input": {
    "user_query": "帮我分析这份财务数据，看看整体毛利率、最赚钱的产品线和表现最好的季度。",
    "session_setup": {
      "uploads": [
        "csv/financial_clean.csv"
      ],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "csv-data-summarizer"
  ],
  "expected_signals": [
    "skill:csv-data-summarizer",
    "tool:Read:/workspace/uploads/",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 12
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "csv-data-summarizer"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "row_count",
      "total_revenue",
      "weighted_gross_margin_pct",
      "top_product_line_by_total_revenue",
      "top_product_line_revenue",
      "best_quarter_by_net_income",
      "best_quarter_net_income"
    ],
    "notes": [
      "weighted_gross_margin_pct 保留两位小数",
      "best_quarter_by_net_income 格式固定为 Qx YYYY"
    ]
  },
  "ground_truth": {
    "row_count": 45,
    "total_revenue": 20651000,
    "weighted_gross_margin_pct": 65.22,
    "top_product_line_by_total_revenue": "SaaS Platform",
    "top_product_line_revenue": 10775000,
    "best_quarter_by_net_income": "Q1 2024",
    "best_quarter_net_income": 795160
  },
  "verifier": {
    "mode": "rubric",
    "target": "script_stdout",
    "checks": [
      {
        "id": "row_count",
        "type": "exact_match",
        "path": "row_count",
        "weight": 0.1
      },
      {
        "id": "total_revenue",
        "type": "numeric_tolerance",
        "path": "total_revenue",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "weighted_gross_margin_pct",
        "type": "numeric_tolerance",
        "path": "weighted_gross_margin_pct",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "top_product_line_by_total_revenue",
        "type": "exact_match",
        "path": "top_product_line_by_total_revenue",
        "weight": 0.15
      },
      {
        "id": "top_product_line_revenue",
        "type": "numeric_tolerance",
        "path": "top_product_line_revenue",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.15
      },
      {
        "id": "best_quarter_by_net_income",
        "type": "exact_match",
        "path": "best_quarter_by_net_income",
        "weight": 0.1
      },
      {
        "id": "best_quarter_net_income",
        "type": "numeric_tolerance",
        "path": "best_quarter_net_income",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.1
      }
    ]
  }
}