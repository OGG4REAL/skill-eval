{
  "task_id": "finance_cli_aip_basic",
  "group": "finance_uplift",
  "eval_type": "uplift",
  "description": "验证典型定投测算场景下，agent 是否能返回可直接校验的结构化 JSON 结果。",
  "input": {
    "user_query": "每月定投 3000 元，年化 8%，投 10 年，最终能有多少钱？",
    "session_setup": {
      "uploads": [],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "fin-advisor-math"
  ],
  "expected_signals": [
    "skill:fin-advisor-math",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 8
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "fin-advisor-math"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "final_value",
      "total_invested",
      "profit",
      "return_rate"
    ],
    "notes": [
      "final_value、total_invested、profit 返回数字",
      "return_rate 返回带百分号的字符串"
    ]
  },
  "ground_truth": {
    "final_value": 548838.11,
    "total_invested": 360000,
    "profit": 188838.11,
    "return_rate": "52.46%"
  },
  "verifier": {
    "mode": "rubric",
    "target": "final_response_json",
    "checks": [
      {
        "id": "final_value",
        "type": "numeric_tolerance",
        "path": "final_value",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.35
      },
      {
        "id": "total_invested",
        "type": "numeric_tolerance",
        "path": "total_invested",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "profit",
        "type": "numeric_tolerance",
        "path": "profit",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.25
      },
      {
        "id": "return_rate",
        "type": "exact_match",
        "path": "return_rate",
        "weight": 0.2
      }
    ]
  }
}