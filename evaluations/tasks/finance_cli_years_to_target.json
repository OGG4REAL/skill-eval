{
  "task_id": "finance_cli_years_to_target",
  "group": "finance_uplift",
  "eval_type": "uplift",
  "description": "验证年限反推场景下，agent 是否能返回可直接校验的结构化 JSON 结果。",
  "input": {
    "user_query": "如果本金是 30 万，按年化 8% 复利增长，大约多久能到 100 万？请只返回一个 JSON 对象，不要输出任何额外解释、Markdown 或代码块。你必须返回以下字段：years_needed、initial_investment、target、growth_multiple、rate_percent。",
    "session_setup": {
      "uploads": [],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": ["no_skill", "with_skill", "skill_v1", "skill_v2"],
  "target_skills": ["fin-advisor-math"],
  "expected_signals": [
    "skill:fin-advisor-math",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 8
  },
  "scoring_weights": {
    "task_success": 0.40,
    "signal_match": 0.20,
    "artifact_match": 0.10,
    "tool_efficiency": 0.10,
    "trajectory_quality": 0.20
  },
  "routing_expectation": {
    "should_activate": ["fin-advisor-math"]
  },
  "output_contract": {
    "format": "json_only",
    "required_fields": [
      "years_needed",
      "initial_investment",
      "target",
      "growth_multiple",
      "rate_percent"
    ],
    "notes": [
      "不要输出 Markdown 代码块",
      "years_needed 返回数字",
      "growth_multiple 和 rate_percent 返回字符串"
    ]
  },
  "ground_truth": {
    "years_needed": 15.64,
    "initial_investment": 300000,
    "target": 1000000,
    "growth_multiple": "3.33x",
    "rate_percent": "8.00%"
  },
  "verifier": {
    "mode": "rubric",
    "target": "final_response_json",
    "checks": [
      {
        "id": "years_needed",
        "type": "numeric_tolerance",
        "path": "years_needed",
        "tolerance": 0.01,
        "weight": 0.4
      },
      {
        "id": "initial_investment",
        "type": "numeric_tolerance",
        "path": "initial_investment",
        "tolerance": 0.01,
        "weight": 0.1
      },
      {
        "id": "target",
        "type": "numeric_tolerance",
        "path": "target",
        "tolerance": 0.01,
        "weight": 0.1
      },
      {
        "id": "growth_multiple",
        "type": "exact_match",
        "path": "growth_multiple",
        "weight": 0.2
      },
      {
        "id": "rate_percent",
        "type": "exact_match",
        "path": "rate_percent",
        "weight": 0.2
      }
    ]
  }
}
