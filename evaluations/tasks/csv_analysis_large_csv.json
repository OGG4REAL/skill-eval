{
  "task_id": "csv_analysis_large_csv",
  "group": "csv_uplift",
  "eval_type": "uplift",
  "description": "验证 skill 在大文件场景下，是否仍能稳定完成脚本化聚合并输出可校验的 JSON 结果。",
  "input": {
    "user_query": "这是一份比较大的财务数据，帮我做个整体分析：按年汇总收入、算算净利率、看看哪条产品线收入最高。",
    "session_setup": {
      "uploads": [
        "csv/financial_large.csv"
      ],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "csv-data-summarizer"
  ],
  "expected_signals": [
    "skill:csv-data-summarizer",
    "tool:Read:/workspace/uploads/",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 14
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "csv-data-summarizer"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "row_count",
      "revenue_by_year",
      "weighted_net_margin_pct",
      "top_product_line_by_total_revenue",
      "top_product_line_revenue"
    ],
    "notes": [
      "revenue_by_year 的键固定为字符串 2023 和 2024",
      "weighted_net_margin_pct 保留两位小数"
    ]
  },
  "ground_truth": {
    "row_count": 5400,
    "revenue_by_year": {
      "2023": 1805280000,
      "2024": 672840000
    },
    "weighted_net_margin_pct": 13.21,
    "top_product_line_by_total_revenue": "SaaS Platform",
    "top_product_line_revenue": 1293000000
  },
  "verifier": {
    "mode": "rubric",
    "target": "script_stdout",
    "checks": [
      {
        "id": "row_count",
        "type": "exact_match",
        "path": "row_count",
        "weight": 0.15
      },
      {
        "id": "revenue_2023",
        "type": "numeric_tolerance",
        "path": "revenue_by_year.2023",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "revenue_2024",
        "type": "numeric_tolerance",
        "path": "revenue_by_year.2024",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "weighted_net_margin_pct",
        "type": "numeric_tolerance",
        "path": "weighted_net_margin_pct",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.15
      },
      {
        "id": "top_product_line_by_total_revenue",
        "type": "exact_match",
        "path": "top_product_line_by_total_revenue",
        "weight": 0.1
      },
      {
        "id": "top_product_line_revenue",
        "type": "numeric_tolerance",
        "path": "top_product_line_revenue",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      }
    ]
  }
}