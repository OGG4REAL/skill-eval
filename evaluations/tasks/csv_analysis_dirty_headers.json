{
  "task_id": "csv_analysis_dirty_headers",
  "group": "csv_uplift",
  "eval_type": "uplift",
  "description": "验证 skill 在脏表头财务 CSV 上，是否能先完成字段映射，再按财务口径返回可验证 JSON。",
  "input": {
    "user_query": "请分析我上传的财务 CSV，并且只返回一个 JSON 对象，不要输出任何额外解释、Markdown 或代码块。这个文件含有脏表头，请先识别原始列名与标准字段的映射，再完成计算。你必须返回以下字段：row_count、resolved_columns、weighted_gross_margin_pct、top_product_line_by_net_income、top_product_line_net_income。resolved_columns 必须是一个对象，且至少包含 month、year、product_line、total_revenue、gross_profit 这 5 个键；值必须填 CSV 中对应的原始列名。计算规则：weighted_gross_margin_pct = gross_profit 总和 / total_revenue 总和 * 100，保留两位小数；金额和比例都返回数字，不要带逗号或百分号。",
    "session_setup": {
      "uploads": ["csv/financial_dirty_headers.csv"],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": ["no_skill", "with_skill", "skill_v1", "skill_v2"],
  "target_skills": ["csv-data-summarizer"],
  "expected_signals": [
    "skill:csv-data-summarizer",
    "tool:Read:/workspace/uploads/",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 14
  },
  "scoring_weights": {
    "task_success": 0.40,
    "signal_match": 0.20,
    "artifact_match": 0.10,
    "tool_efficiency": 0.10,
    "trajectory_quality": 0.20
  },
  "routing_expectation": {
    "should_activate": ["csv-data-summarizer"]
  },
  "output_contract": {
    "format": "json_only",
    "required_fields": [
      "row_count",
      "resolved_columns",
      "weighted_gross_margin_pct",
      "top_product_line_by_net_income",
      "top_product_line_net_income"
    ],
    "notes": [
      "不要输出 Markdown 代码块",
      "resolved_columns 的值必须保留原始列名写法",
      "weighted_gross_margin_pct 保留两位小数"
    ]
  },
  "ground_truth": {
    "row_count": 45,
    "resolved_columns": {
      "month": "Month Name",
      "year": "Fiscal-Year",
      "product_line": "Product-Line",
      "total_revenue": "Sales Amount($)",
      "gross_profit": "Gross Profit"
    },
    "weighted_gross_margin_pct": 65.22,
    "top_product_line_by_net_income": "SaaS Platform",
    "top_product_line_net_income": 1764325
  },
  "verifier": {
    "mode": "rubric",
    "target": "final_response_json",
    "checks": [
      {
        "id": "row_count",
        "type": "exact_match",
        "path": "row_count",
        "expected": 45,
        "weight": 0.1
      },
      {
        "id": "resolved_columns",
        "type": "json_subset",
        "path": "resolved_columns",
        "expected": {
          "month": "Month Name",
          "year": "Fiscal-Year",
          "product_line": "Product-Line",
          "total_revenue": "Sales Amount($)",
          "gross_profit": "Gross Profit"
        },
        "weight": 0.35
      },
      {
        "id": "weighted_gross_margin_pct",
        "type": "numeric_tolerance",
        "path": "weighted_gross_margin_pct",
        "expected": 65.22,
        "tolerance": 0.01,
        "weight": 0.2
      },
      {
        "id": "top_product_line_by_net_income",
        "type": "exact_match",
        "path": "top_product_line_by_net_income",
        "expected": "SaaS Platform",
        "weight": 0.15
      },
      {
        "id": "top_product_line_net_income",
        "type": "numeric_tolerance",
        "path": "top_product_line_net_income",
        "expected": 1764325,
        "tolerance": 0.01,
        "weight": 0.2
      }
    ]
  }
}
