{
  "task_id": "csv_analysis_dirty_headers",
  "group": "csv_uplift",
  "eval_type": "uplift",
  "description": "验证 skill 在脏表头财务 CSV 上，是否能先完成字段映射，再按财务口径产出可验证 JSON。",
  "input": {
    "user_query": "这个 CSV 的列名比较乱，帮我识别关键字段后做个财务分析，看看毛利率和哪条产品线净利润最高。",
    "session_setup": {
      "uploads": [
        "csv/financial_dirty_headers.csv"
      ],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "csv-data-summarizer"
  ],
  "expected_signals": [
    "skill:csv-data-summarizer",
    "tool:Read:/workspace/uploads/",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 14
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "csv-data-summarizer"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "row_count",
      "weighted_gross_margin_pct",
      "top_product_line_by_net_income",
      "top_product_line_net_income"
    ],
    "notes": [
      "weighted_gross_margin_pct 保留两位小数，须用 gross_profit/revenue 加权计算而非对 margin_pct 列取均值",
      "top_product_line_by_net_income 须识别 'Product-Line' 列"
    ]
  },
  "ground_truth": {
    "row_count": 45,
    "weighted_gross_margin_pct": 65.22,
    "top_product_line_by_net_income": "SaaS Platform",
    "top_product_line_net_income": 1764325
  },
  "verifier": {
    "mode": "rubric",
    "target": "script_stdout",
    "checks": [
      {
        "id": "row_count",
        "type": "exact_match",
        "path": "row_count",
        "weight": 0.15
      },
      {
        "id": "weighted_gross_margin_pct",
        "type": "numeric_tolerance",
        "path": "weighted_gross_margin_pct",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.35
      },
      {
        "id": "top_product_line_by_net_income",
        "type": "exact_match",
        "path": "top_product_line_by_net_income",
        "weight": 0.2
      },
      {
        "id": "top_product_line_net_income",
        "type": "numeric_tolerance",
        "path": "top_product_line_net_income",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.3
      }
    ]
  }
}