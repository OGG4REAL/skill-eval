{
  "task_id": "csv_analysis_clean_general",
  "group": "csv_uplift",
  "eval_type": "uplift",
  "description": "验证 skill 在干净的非财务 CSV 上，是否能通过脚本产出可校验的结构化 JSON 结果。",
  "input": {
    "user_query": "帮我分析一下这份销售数据，哪个区域表现最好？退款情况怎么样？",
    "session_setup": {
      "uploads": [
        "csv/regional_sales_clean.csv"
      ],
      "workspace_files": [],
      "history_seed": []
    }
  },
  "variants": [
    "no_skill",
    "with_skill"
  ],
  "target_skills": [
    "csv-data-summarizer"
  ],
  "expected_signals": [
    "skill:csv-data-summarizer",
    "tool:Read:/workspace/uploads/",
    "tool:Write:/workspace/temp/",
    "tool:Bash"
  ],
  "forbidden_signals": [],
  "expected_artifacts": [
    "/workspace/temp/*.py"
  ],
  "pass_criteria": {
    "final_response_non_empty": true,
    "tool_errors_max": 0,
    "iterations_max": 12
  },
  "scoring_weights": {
    "result_score": 0.6,
    "task_success": 0.2,
    "signal_match": 0.1,
    "tool_efficiency": 0.1
  },
  "routing_expectation": {
    "should_activate": [
      "csv-data-summarizer"
    ]
  },
  "output_contract": {
    "format": "json",
    "required_fields": [
      "row_count",
      "total_revenue",
      "top_region_by_revenue",
      "top_region_revenue",
      "highest_refund_rate_region",
      "highest_refund_rate_pct"
    ],
    "notes": [
      "金额和比例都返回数字",
      "highest_refund_rate_pct 保留两位小数"
    ]
  },
  "ground_truth": {
    "row_count": 12,
    "total_revenue": 242560,
    "top_region_by_revenue": "East",
    "top_region_revenue": 83400,
    "highest_refund_rate_region": "West",
    "highest_refund_rate_pct": 7.12
  },
  "verifier": {
    "mode": "rubric",
    "target": "script_stdout",
    "checks": [
      {
        "id": "row_count",
        "type": "exact_match",
        "path": "row_count",
        "weight": 0.15
      },
      {
        "id": "total_revenue",
        "type": "numeric_tolerance",
        "path": "total_revenue",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "top_region_by_revenue",
        "type": "exact_match",
        "path": "top_region_by_revenue",
        "weight": 0.15
      },
      {
        "id": "top_region_revenue",
        "type": "numeric_tolerance",
        "path": "top_region_revenue",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      },
      {
        "id": "highest_refund_rate_region",
        "type": "exact_match",
        "path": "highest_refund_rate_region",
        "weight": 0.1
      },
      {
        "id": "highest_refund_rate_pct",
        "type": "numeric_tolerance",
        "path": "highest_refund_rate_pct",
        "tolerance": 0.001,
        "tolerance_mode": "relative",
        "weight": 0.2
      }
    ]
  },
  "input_patterns": [
    "分析我上传的 csv",
    "分析这个 csv",
    "分析一下 csv",
    "分析csv"
  ]
}