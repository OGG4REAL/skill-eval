# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 项目路径配置
SKILLS_DIR=./skills
SESSIONS_ROOT=./sessions

# Docker MCP 沙箱配置
SANDBOX_IMAGE=claude-skills-sandbox:latest
DOCKER_CPUS=2
DOCKER_MEMORY=2g

# Agent 行为配置
MAX_ITERATIONS=30                # Agent 最大迭代次数（默认 30）
RESPONSE_LANGUAGE=zh-CN          # 回复语言：zh-CN (中文) 或 en-US (英文)
